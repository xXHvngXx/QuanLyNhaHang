<Window x:Class="RestaurantManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantManagementSystem"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Nhà Hàng" 
        Height="768" Width="1024" 
        WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#2D3436">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="NGHIỆP VỤ" Foreground="#636E72" FontWeight="Bold" Margin="15,20,0,10" FontSize="11"/>

                <Button x:Name="btnPhucVu" Content="👩‍🍳 Phục Vụ" Click="btnPhucVu_Click" Height="55" 
            Background="Transparent" Foreground="White" BorderThickness="0" 
            FontSize="14" FontWeight="Bold"/>

                <Button x:Name="btnThuNgan" Content="💰 Thu Ngân" Click="btnThuNgan_Click" Height="55" 
            Background="Transparent" Foreground="White" BorderThickness="0" 
            FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel x:Name="spAdminSection" Grid.Row="1" Margin="0,0,0,20">
                <Separator Background="#636E72" Margin="15,0,15,15" Height="1" BorderThickness="0"/>

                <Button x:Name="btnAdmin" Click="btnAdmin_Click" Height="50" Margin="10,0,10,0"
            Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <TextBlock Text="👑 QUẢN TRỊ" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="10"/>
    </Grid>
</Window>