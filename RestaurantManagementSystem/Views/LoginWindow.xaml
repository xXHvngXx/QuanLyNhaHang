<Window x:Class="RestaurantManagementSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" Height="500" Width="400" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                        BorderThickness="0" Foreground="Gray" Click="btnClose_Click"/>

                <TextBlock Text="WELCOME" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2D3436" Margin="0,10,0,0"/>

                <TextBlock Text="Vui lòng đăng nhập để tiếp tục" HorizontalAlignment="Center" 
                           Foreground="Gray" Margin="0,5,0,25"/>

                <TextBlock Text="Tài khoản" Foreground="#636E72" Margin="0,10,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DFE6E9" BorderThickness="1" CornerRadius="10" Padding="5">
                    <TextBox x:Name="txtUsername" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" VerticalContentAlignment="Center" Height="30"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#636E72" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DFE6E9" BorderThickness="1" CornerRadius="10" Padding="5">
                    <Grid>
                        <PasswordBox x:Name="txtPassword" BorderThickness="0" VerticalContentAlignment="Center" Height="30" Padding="0,0,30,0"/>

                        <TextBox x:Name="txtPasswordVisible" BorderThickness="0" VerticalContentAlignment="Center" Height="30" Padding="0,0,30,0" Visibility="Collapsed"/>

                        <Button Style="{StaticResource EyeButtonStyle}" 
                                Content="👁" 
                                HorizontalAlignment="Right" 
                                Width="30" Height="30"
                                PreviewMouseDown="Eye_PreviewMouseDown" 
                                PreviewMouseUp="Eye_PreviewMouseUp"/>
                    </Grid>
                </Border>

                <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Margin="0,35,0,0" Height="45"
                        Background="#0984E3" Foreground="White" FontWeight="Bold" Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=txtPassword}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Chưa có tài khoản? Đăng ký ngay" 
                        Margin="0,15,0,0" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Foreground="#0984E3" 
                        Cursor="Hand" 
                        Click="btnShowRegister_Click"/>
            </StackPanel>

            <Border x:Name="brdSuccess" Background="#27ae60" CornerRadius="20" 
                    Visibility="Collapsed" Opacity="0" VerticalAlignment="Center" 
                    HorizontalAlignment="Center" Padding="30,20" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔" Foreground="White" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="ĐĂNG NHẬP THÀNH CÔNG" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Chào mừng bạn quay trở lại!" Foreground="#e0e0e0" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="brdError" Background="#e74c3c" CornerRadius="20" 
                    Visibility="Collapsed" Opacity="0" VerticalAlignment="Center" 
                    HorizontalAlignment="Center" Padding="30,20" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✖" Foreground="White" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="ĐĂNG NHẬP THẤT BẠI" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Sai tài khoản hoặc mật khẩu!" Foreground="#f5f5f5" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>