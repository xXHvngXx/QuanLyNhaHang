<UserControl x:Class="RestaurantManagementSystem.Views.ucAccount"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
             Background="#F5F6FA">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- BÊN TRÁI: FORM NHẬP LIỆU -->
        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="👥 QUẢN LÝ TÀI KHOẢN" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <TextBlock Text="Tên đăng nhập (UserName):" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUserName" 
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsUserNameReadOnly}"
                         Height="35" Padding="10,8" Margin="0,0,0,15"/>

                <TextBlock Text="Tên hiển thị:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDisplayName" 
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Padding="10,8" Margin="0,0,0,15"/>

                <TextBlock Text="Loại tài khoản:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>

                <!-- SỬA TẠI ĐÂY: Thêm đủ 3 loại và đúng thứ tự Index 0, 1, 2 -->
                <ComboBox x:Name="cbAccountType" 
                          SelectedIndex="{Binding AccountType}"
                          Height="35" Padding="10,8" Margin="0,0,0,25">
                    <ComboBoxItem Content="Quản trị viên (Directeur)"/>
                    <!-- Index 0 = Role 0 -->
                    <ComboBoxItem Content="Nhân viên phục vụ (Serveur)"/>
                    <!-- Index 1 = Role 1 -->
                    <ComboBoxItem Content="Nhân viên thu ngân (Caissier)"/>
                    <!-- Index 2 = Role 2 -->
                </ComboBox>

                <UniformGrid Columns="2" Rows="2" VerticalAlignment="Top" Margin="0,0,0,15">
                    <Button Command="{Binding AddCommand}" Content="➕ Thêm" Height="40" Margin="0,0,5,5" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Command="{Binding EditCommand}" Content="✏️ Sửa" Height="40" Margin="5,0,0,5" Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Command="{Binding DeleteCommand}" Content="🗑️ Xóa" Height="40" Margin="0,5,5,0" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Command="{Binding ClearCommand}" Content="🔄 Nhập lại" Height="40" Margin="5,5,0,0" Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </UniformGrid>

                <Button Command="{Binding ResetPasswordCommand}" Content="🔑 Đặt lại mật khẩu mặc định" Height="40" Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- BÊN PHẢI: DANH SÁCH TÀI KHOẢN -->
        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="DANH SÁCH TÀI KHOẢN" FontWeight="Bold" Foreground="#34495E" Margin="5,0,0,10"/>

                <DataGrid x:Name="dgAccount" Grid.Row="1" 
                          ItemsSource="{Binding AccountList}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single"
                          Background="White" RowHeight="35" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Đăng Nhập" Binding="{Binding UserName}" Width="120"/>
                        <DataGridTextColumn Header="Tên Hiển Thị" Binding="{Binding DisplayName}" Width="*"/>

                        <!-- HIỂN THỊ CHỮ THAY VÌ SỐ ROLE -->
                        <DataGridTemplateColumn Header="Quyền" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="0">
                                                        <Setter Property="Text" Value="Quản trị"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="1">
                                                        <Setter Property="Text" Value="Phục vụ"/>
                                                        <Setter Property="Foreground" Value="#2C3E50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="2">
                                                        <Setter Property="Text" Value="Thu ngân"/>
                                                        <Setter Property="Foreground" Value="#2980B9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>