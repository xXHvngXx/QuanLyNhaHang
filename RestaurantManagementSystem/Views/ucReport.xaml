<UserControl x:Class="RestaurantManagementSystem.Views.ucReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             Background="#F5F6FA" Loaded="UserControl_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <DatePicker x:Name="dtpFrom" Width="150" Height="35" 
                            SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectedDateChanged">
                            <i:InvokeCommandAction Command="{Binding LoadReportCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </DatePicker>

                <TextBlock Text=" ➔ " VerticalAlignment="Center" Margin="10,0"/>

                <DatePicker x:Name="dtpTo" Width="150" Height="35" 
                            SelectedDate="{Binding ToDate, UpdateSourceTrigger=PropertyChanged}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectedDateChanged">
                            <i:InvokeCommandAction Command="{Binding LoadReportCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </DatePicker>

                <Button Command="{Binding LoadReportCommand}" 
                        Content="🔍 Xem Báo Cáo" Width="130" Height="35" Margin="20,0,0,0" 
                        Background="#2980B9" Foreground="White" BorderThickness="0" FontWeight="Bold"/>

                <Button Command="{Binding ExportExcelCommand}" 
                        Content="📄 Xuất File Excel" Width="150" Height="35" Margin="15,0,0,0" 
                        Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <DataGrid x:Name="dgBill" ItemsSource="{Binding BillList}" 
                      AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ" Binding="{Binding BillID}" Width="60"/>
                    <DataGridTextColumn Header="Bàn" Binding="{Binding TableName}" Width="100"/>
                    <DataGridTextColumn Header="Ngày ra" Binding="{Binding DateCheckOut, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                    <DataGridTextColumn Header="Doanh thu" Binding="{Binding TotalPrice, StringFormat={}{0:N0} VNĐ}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="📈 XU HƯỚNG DOANH THU" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10"/>

                <lvc:CartesianChart Grid.Row="1" LegendLocation="None" Hoverable="True">
                    <lvc:CartesianChart.Series>
                        <lvc:LineSeries x:Name="ChartSeries" 
                                        Title="Doanh thu" 
                                        Values="{Binding ChartValues}" 
                                        StrokeThickness="4" 
                                        PointGeometrySize="12"
                                        PointForeground="White"
                                        LineSmoothness="0.6">
                            <lvc:LineSeries.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#2ECC71" Offset="0" />
                                    <GradientStop Color="#002ECC71" Offset="1" />
                                </LinearGradientBrush>
                            </lvc:LineSeries.Fill>
                        </lvc:LineSeries>
                    </lvc:CartesianChart.Series>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Ngày" Labels="{Binding ChartLabels}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1" IsEnabled="False"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Tiền (VNĐ)" LabelFormatter="{Binding YFormatter}">
                            <lvc:Axis.Separator>
                                <lvc:Separator StrokeThickness="1" Stroke="#F0F0F0" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</UserControl>