<UserControl x:Class="RestaurantManagementSystem.Views.ucMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             Background="#F5F6FA">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🛡️ HỆ THỐNG GIÁM SÁT KẾT HỢP CAMERA" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
            <Button Command="{Binding RefreshCommand}" Content="🔄 Làm mới" Margin="20,0,0,0" Width="110" Height="30" Background="#34495E" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="1" Background="Black" CornerRadius="10" Margin="0,0,0,20">
            <Grid>
                <TextBlock Text="{Binding CameraNote}" Foreground="Lime" Margin="15" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text="● REC" Foreground="Red" HorizontalAlignment="Right" Margin="15" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📷" FontSize="50" Foreground="White" Opacity="0.2" HorizontalAlignment="Center"/>
                    <TextBlock Text="SENSING HUMAN ACTIVITY..." Foreground="White" Opacity="0.5" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding StaffList}" Margin="0,0,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="210" Height="150" Margin="0,0,15,15" Background="White" CornerRadius="12" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding ChucVu}" Foreground="#95A5A6" HorizontalAlignment="Center" FontSize="12"/>
                            </StackPanel>

                            <Border CornerRadius="15" Padding="12,3" HorizontalAlignment="Center" Margin="0,5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG TẠI BÀN">
                                                <Setter Property="Background" Value="#FDEDEC"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG GIAO DỊCH">
                                                <Setter Property="Background" Value="#EBF5FB"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG CHỜ">
                                                <Setter Property="Background" Value="#EAFAF1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TrangThai}" FontWeight="Bold" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG TẠI BÀN">
                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG GIAO DỊCH">
                                                    <Setter Property="Foreground" Value="#3498DB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="ĐANG CHỜ">
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="{Binding CongViecHienTai}" FontSize="11" Foreground="#7F8C8D" HorizontalAlignment="Center" FontStyle="Italic"/>

                            <TextBlock Text="{Binding ChiSoAnToan}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChiSoAnToan}" Value="✅ Tốt">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChiSoAnToan}" Value="⚠️ RỦI RO: XÓA NHIỀU">
                                                <Setter Property="Foreground" Value="#E67E22"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChiSoAnToan}" Value="💤 ĐANG NGHỈ LÂU">
                                                <Setter Property="Foreground" Value="#8E44AD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="⚠️ PHÂN TÍCH HÀNH VI NGHI VẤN (AI CAMERA &amp; LOG)" FontWeight="Bold" Margin="0,0,0,10" Foreground="#E67E22"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding AuditLogs}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding [Ngày], StringFormat=\{0:dd/MM\}}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7F8C8D"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Bill" Binding="{Binding [Mã Bill]}" Width="50"/>

                        <DataGridTextColumn Header="Giờ" Binding="{Binding [Giờ]}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Hành động" Binding="{Binding [Hành Động]}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding [Hành Động]}" Value="XÓA MÓN">
                                            <Setter Property="Foreground" Value="#E67E22"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding [Hành Động]}" Value="GIẢM MÓN">
                                            <Setter Property="Foreground" Value="#F1C40F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding [Hành Động]}" Value="THANH TOÁN">
                                            <Setter Property="Foreground" Value="#3498DB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tiền Trước" Binding="{Binding [Tiền Trước], StringFormat={}{0:N0}}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#95A5A6"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tiền Sau" Binding="{Binding [Tiền Sau], StringFormat={}{0:N0}}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                    <Style.Triggers>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding [Nhân Viên]}" Width="100"/>

                        <DataGridTextColumn Header="Chi Tiết" Binding="{Binding [Chi Tiết]}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>