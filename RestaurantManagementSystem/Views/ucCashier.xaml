<UserControl x:Class="RestaurantManagementSystem.Views.ucCashier"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2F3640" CornerRadius="15" Padding="12" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="5,0,0,10">
                    <TextBlock Text="🍽 DANH SÁCH BÀN" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <Rectangle Height="1" Fill="#57606F" Margin="0,5,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}"
                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8">
                                <Border Width="100" Height="80" CornerRadius="12" Padding="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#44BD32"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="1">
                                                    <Setter Property="Background" Value="#E84118"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TableName}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="#F5F5F5" FontSize="10" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#F1C40F" BorderThickness="3" CornerRadius="12" 
                                        Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="5" Background="White" CornerRadius="15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🧾 CHI TIẾT HÓA ĐƠN" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2D3436"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding BillDetails}" SelectedItem="{Binding SelectedBillDetail}"
                          AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="0" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Món ăn" Binding="{Binding FoodName}" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="40"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="80"/>
                        <DataGridTextColumn Header="Tổng" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="15" Padding="15" Margin="5">
            <StackPanel>
                <TextBlock Text="🛠 ĐIỀU CHỈNH" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                          DisplayMemberPath="CategoryName" Height="35" Margin="0,5"/>
                <ComboBox ItemsSource="{Binding Foods}" SelectedItem="{Binding SelectedFood}" 
                          DisplayMemberPath="FoodName" Height="35" Margin="0,5"/>

                <Grid Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Height="35" Margin="0,0,5,0" TextAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Note}" Height="35"/>
                </Grid>

                <UniformGrid Columns="2" Rows="2" Height="85">
                    <Button Content="THÊM MỚI" Command="{Binding AddFoodCommand}" Background="#00B894" Foreground="White" BorderThickness="0" Margin="2"/>
                    <Button Content="CẬP NHẬT SL" Command="{Binding UpdateFoodCommand}" Background="#F1C40F" Foreground="White" BorderThickness="0" Margin="2"/>
                    <Button Content="XÓA MÓN" Command="{Binding DeleteFoodCommand}" Background="#E17055" Foreground="White" BorderThickness="0" Margin="2"/>
                    <Button Content="THANH TOÁN" Click="btnShowPayConfirm_Click" Background="#00A8FF" Foreground="White" BorderThickness="0" Margin="2"/>
                </UniformGrid>

                <Separator Margin="0,15"/>
                <TextBlock Text="TỔNG TIỀN:" Foreground="Gray"/>
                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} VNĐ}" FontSize="24" FontWeight="Bold" Foreground="#E84118"/>

                <Button Content="XEM BILL &amp; IN" 
                    Command="{Binding PrintBillCommand}" 
                    Height="40" Margin="0,10" 
                    Background="#9C88FF" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid x:Name="payConfirmOverlay" Grid.ColumnSpan="3" Background="#B2000000" Visibility="Collapsed" Panel.ZIndex="99">
            <Border Background="White" Width="400" VerticalAlignment="Center" CornerRadius="20" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="💰 XÁC NHẬN THANH TOÁN" FontSize="20" FontWeight="Bold" Foreground="#2D3436" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Bạn có chắc chắn muốn thanh toán cho:" HorizontalAlignment="Center" Foreground="#636E72" FontSize="14"/>
                    <TextBlock Text="{Binding SelectedTable.TableName}" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#E84118" Margin="0,5"/>
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,15">
                        <Grid>
                            <TextBlock Text="TỔNG TIỀN:" VerticalAlignment="Center" Foreground="#2D3436"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} VNĐ}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                        </Grid>
                    </Border>
                    <UniformGrid Columns="2" Height="45">
                        <Button Content="HỦY BỎ" Click="btnCancelPay_Click" Background="#DFE6E9" Foreground="#2D3436" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        <Button Content="THANH TOÁN NGAY" Command="{Binding PayCommand}" Click="btnConfirmPay_Click" Background="#00A8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="brdSuccessNotify" Background="#27ae60" CornerRadius="20" 
                Visibility="Collapsed" Opacity="0" VerticalAlignment="Center" 
                HorizontalAlignment="Center" Padding="30,20" Panel.ZIndex="100"
                Grid.ColumnSpan="3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✔" Foreground="White" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock x:Name="txtNotifyTitle" Text="THÀNH CÔNG" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="txtNotifyContent" Text="Thao tác đã được thực hiện!" Foreground="#e0e0e0" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>