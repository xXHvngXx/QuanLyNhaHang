<UserControl x:Class="RestaurantManagementSystem.Views.ucFood"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             Background="#F5F6FA">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🍔 QUẢN LÝ MÓN ĂN" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <TextBlock Text="Mã món (ID):" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFoodID" Text="{Binding FoodID}" Height="35" IsReadOnly="True" Background="#ECF0F1" Padding="10,8" Margin="0,0,0,15"/>

                <TextBlock Text="Tên món ăn:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFoodName" Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,8" Margin="0,0,0,15"/>

                <TextBlock Text="Danh mục:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbCategory" 
                          ItemsSource="{Binding CategoryList}"
                          SelectedValue="{Binding SelectedCategoryID}"
                          DisplayMemberPath="CategoryName" 
                          SelectedValuePath="CategoryID"
                          Height="35" Padding="10,8" Margin="0,0,0,15"/>

                <TextBlock Text="Giá tiền (VNĐ):" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPrice" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,8" Margin="0,0,0,25"/>

                <UniformGrid Columns="2" Rows="2" VerticalAlignment="Top">
                    <Button Content="➕ Thêm" Command="{Binding AddCommand}" Height="40" Margin="0,0,5,5" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="✏️ Sửa" Command="{Binding EditCommand}" Height="40" Margin="5,0,0,5" Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Height="40" Margin="0,5,5,0" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="🔄 Nhập lại" Command="{Binding ClearCommand}" Height="40" Margin="5,5,0,0" Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="THỰC ĐƠN HIỆN TẠI" FontWeight="Bold" Foreground="#34495E" Margin="5,0,0,10"/>

                <DataGrid x:Name="dgFood" 
                          ItemsSource="{Binding FoodList}"
                          SelectedItem="{Binding SelectedFood}"
                          Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single"
                          Background="White" RowHeight="35" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding FoodID}" Width="50"/>
                        <DataGridTextColumn Header="Tên Món" Binding="{Binding FoodName}" Width="*"/>
                        <DataGridTextColumn Header="ID Danh Mục" Binding="{Binding CategoryID}" Width="100"/>
                        <DataGridTextColumn Header="Giá Tiền" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>