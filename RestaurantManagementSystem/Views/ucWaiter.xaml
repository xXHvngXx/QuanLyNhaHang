<UserControl x:Class="RestaurantManagementSystem.Views.ucWaiter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="UserControl_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="15" Padding="15" Margin="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ĐỊNH VỊ BÀN" FontSize="18" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" ClipToBounds="False" Padding="0,10,0,10">
                    <ListBox x:Name="icTables" Background="Transparent" BorderThickness="0" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ClipToBounds="False">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="GridTable" Margin="5,35,5,10">
                                    <Canvas HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed" x:Name="CanvasSelectedArrow">
                                        <TextBlock Text="▼" FontSize="20" FontWeight="Bold" Foreground="#F1C40F" HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform X="-7" Y="-25" x:Name="SelectedArrowTransform"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Triggers>
                                                <EventTrigger RoutedEvent="TextBlock.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="SelectedArrowTransform"
                                                                             Storyboard.TargetProperty="Y"
                                                                             From="-25" To="-15" Duration="0:0:0.5" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </TextBlock.Triggers>
                                        </TextBlock>
                                    </Canvas>

                                    <Border x:Name="TableContainer" CornerRadius="10" BorderThickness="3" BorderBrush="Transparent">
                                        <Button Width="90" Height="90" Margin="0" Click="btnTable_Click" Tag="{Binding TableID}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#00B894"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Content" Value="{Binding TableName}"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Background" Value="#FF7675"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Border>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <Trigger SourceName="TableContainer" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TableContainer" Property="BorderBrush" Value="#2D3436"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="CanvasSelectedArrow" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="TableContainer" Property="BorderBrush" Value="#F1C40F"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="15" Margin="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtSelectedTable" Grid.Row="0" 
                           Text="📍 Đang order cho: " 
                           FontSize="20" FontWeight="Bold" Foreground="#E84118" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Danh mục" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbCategory" Width="130" Height="35" SelectionChanged="cbCategory_SelectionChanged" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Món ăn" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbFood" Width="140" Height="35" DisplayMemberPath="FoodName" SelectedValuePath="FoodID"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="SL" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtQuantity" Width="45" Height="35" Text="1" TextAlignment="Center" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="THÊM" Width="65" Height="35" Margin="0,20,4,0" Background="#0984E3" Foreground="White" FontWeight="Bold" Click="btnAddFood_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="SỬA SL" Width="65" Height="35" Margin="0,20,4,0" Background="#6C5CE7" Foreground="White" FontWeight="Bold" Click="btnUpdateFood_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="XÓA" Width="65" Height="35" Margin="0,20,0,0" Background="#D63031" Foreground="White" FontWeight="Bold" Click="btnDeleteFood_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgOrderBill" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                          Background="White" BorderThickness="1" BorderBrush="#DFE6E9"
                          RowHeight="35" ColumnHeaderHeight="40"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F2F6">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Foreground" Value="#2D3436"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="LeftHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên" Binding="{Binding FoodName}" Width="*" HeaderStyle="{StaticResource LeftHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Tổng" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#E84118"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>