<UserControl x:Class="RestaurantManagementSystem.Views.ucWaiter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="15" Padding="15" Margin="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ĐỊNH VỊ BÀN" FontSize="18" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,10,0,10">
                    <ListBox x:Name="icTables" 
                             ItemsSource="{Binding Tables}" 
                             SelectedItem="{Binding SelectedTable}"
                             Background="Transparent" BorderThickness="0" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="GridTable" Margin="5,35,5,10">
                                    <Canvas HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed" x:Name="CanvasSelectedArrow">
                                        <TextBlock Text="▼" FontSize="20" FontWeight="Bold" Foreground="#F1C40F" HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform X="-7" Y="-25" x:Name="SelectedArrowTransform"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Triggers>
                                                <EventTrigger RoutedEvent="TextBlock.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="SelectedArrowTransform"
                                                                             Storyboard.TargetProperty="Y"
                                                                             From="-25" To="-15" Duration="0:0:0.5" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </TextBlock.Triggers>
                                        </TextBlock>
                                    </Canvas>

                                    <Border x:Name="TableContainer" CornerRadius="10" BorderThickness="3" BorderBrush="Transparent">
                                        <Grid Width="90" Height="90">
                                            <Border x:Name="InnerBorder" CornerRadius="8" Background="#00B894">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TableName}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="1">
                                        <Setter TargetName="InnerBorder" Property="Background" Value="#FF7675"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="0">
                                        <Setter TargetName="InnerBorder" Property="Background" Value="#00B894"/>
                                    </DataTrigger>

                                    <Trigger SourceName="TableContainer" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TableContainer" Property="BorderBrush" Value="#2D3436"/>
                                        <Setter TargetName="InnerBorder" Property="Opacity" Value="0.8"/>
                                    </Trigger>

                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="CanvasSelectedArrow" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="TableContainer" Property="BorderBrush" Value="#F1C40F"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="15" Margin="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="📍 Đang order cho: " FontSize="20" FontWeight="Bold" Foreground="#E84118"/>
                    <TextBlock Text="{Binding SelectedTable.TableName}" FontSize="20" FontWeight="Bold" Foreground="#E84118"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Danh mục" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Width="110" Height="35" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName" />
                    </StackPanel>

                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Món ăn" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Width="120" Height="35" ItemsSource="{Binding Foods}" SelectedItem="{Binding SelectedFood}" DisplayMemberPath="FoodName"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="SL" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Width="40" Height="35" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="THÊM" Command="{Binding AddFoodCommand}" Width="55" Height="35" Margin="0,20,4,0" Background="#0984E3" Foreground="White" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="SỬA" Command="{Binding UpdateFoodCommand}" CommandParameter="{Binding SelectedItem, ElementName=dgOrderBill}" Width="55" Height="35" Margin="0,20,4,0" Background="#F1C40F" Foreground="#2D3436" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="XÓA" Command="{Binding DeleteFoodCommand}" CommandParameter="{Binding SelectedItem, ElementName=dgOrderBill}" Width="55" Height="35" Margin="0,20,4,0" Background="#D63031" Foreground="White" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="🔄" Command="{Binding LoadDataCommand}" Width="40" Height="35" Margin="0,20,0,0" Background="#636E72" Foreground="White" FontSize="16">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgOrderBill" Grid.Row="2" 
                          ItemsSource="{Binding BillDetails}" 
                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                          Background="White" BorderThickness="1" BorderBrush="#DFE6E9"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F2F6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên món" Binding="{Binding FoodName}" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="90"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>