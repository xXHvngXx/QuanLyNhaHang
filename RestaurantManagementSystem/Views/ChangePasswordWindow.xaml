<Window x:Class="RestaurantManagementSystem.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="wdChangePass"
        Title="Đổi mật khẩu" Height="420" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="White" BorderBrush="#D1D1D1" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#2B2B2B" Grid.Row="0" CornerRadius="14,14,0,0">
                <Grid>
                    <TextBlock Text="THAY ĐỔI MẬT KHẨU" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="40" Background="Transparent" Foreground="White" Click="CloseButton_Click" Cursor="Hand"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="35,20,35,20">
                <TextBlock Text="Mật khẩu hiện tại" Foreground="#444444" Margin="0,0,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtOldPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtOldPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="Old"/>
                </Grid>

                <TextBlock Text="Mật khẩu mới" Foreground="#444444" Margin="0,15,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtNewPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtNewPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="New"/>
                </Grid>

                <TextBlock Text="Xác nhận mật khẩu mới" Foreground="#444444" Margin="0,15,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtConfirmPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtConfirmPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="Confirm"/>
                </Grid>

                <Grid Margin="0,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="XÁC NHẬN" Click="btnShowConfirm_Click" Grid.Column="0" Margin="0,0,5,0" Height="35" Background="#2B2B2B" Foreground="White" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="HỦY BỎ" Grid.Column="1" Margin="5,0,0,0" Height="35" Background="#E1E1E1" Foreground="#333333" FontWeight="Bold" Click="CloseButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>

            <Grid x:Name="confirmOverlay" Grid.RowSpan="2" Background="#B2000000" Visibility="Collapsed" Panel.ZIndex="10">
                <Border Background="White" Width="320" VerticalAlignment="Center" CornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🔑 XÁC NHẬN" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Bạn có chắc chắn muốn thay đổi mật khẩu không?" TextWrapping="Wrap" TextAlignment="Center" Foreground="#636E72" Margin="0,0,0,20"/>
                        <UniformGrid Columns="2" Height="38">
                            <Button Content="QUAY LẠI" Click="btnCancelConfirm_Click" Background="#DFE6E9" BorderThickness="0" Margin="5" Cursor="Hand"/>
                            <Button Content="ĐỒNG Ý" Click="btnFinalConfirm_Click" Background="#2B2B2B" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="brdNotify" Grid.RowSpan="2" Background="#27ae60" CornerRadius="10" 
                    Visibility="Collapsed" Opacity="0" VerticalAlignment="Top" 
                    HorizontalAlignment="Center" Padding="20,10" Margin="0,50,0,0" Panel.ZIndex="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock Text="Đổi mật khẩu thành công!" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>