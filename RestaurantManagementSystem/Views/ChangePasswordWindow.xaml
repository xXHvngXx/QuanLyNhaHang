<Window x:Class="RestaurantManagementSystem.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="wdChangePass"
        Title="Đổi mật khẩu" Height="420" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="White" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- Style cho nút con mắt giống Dell/Windows -->
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#D1D1D1" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Background="#2B2B2B" Grid.Row="0">
                <Grid>
                    <TextBlock Text="THAY ĐỔI MẬT KHẨU" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="40" Background="Transparent" Foreground="White" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="35,20,35,20">

                <!-- Ô mật khẩu cũ -->
                <TextBlock Text="Mật khẩu hiện tại" Foreground="#444444" Margin="0,0,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtOldPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtOldPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="Old"/>
                </Grid>

                <!-- Ô mật khẩu mới -->
                <TextBlock Text="Mật khẩu mới" Foreground="#444444" Margin="0,15,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtNewPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtNewPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="New"/>
                </Grid>

                <!-- Ô xác nhận mật khẩu -->
                <TextBlock Text="Xác nhận mật khẩu mới" Foreground="#444444" Margin="0,15,0,5"/>
                <Grid>
                    <PasswordBox x:Name="txtConfirmPass" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA"/>
                    <TextBox x:Name="txtConfirmPassVisible" Height="32" VerticalContentAlignment="Center" Padding="5,0,30,0" BorderBrush="#BABABA" Visibility="Collapsed"/>
                    <Button Style="{StaticResource EyeButtonStyle}" Content="👁" HorizontalAlignment="Right" Width="30" Height="32"
                            PreviewMouseDown="Eye_PreviewMouseDown" PreviewMouseUp="Eye_PreviewMouseUp" Tag="Confirm"/>
                </Grid>

                <!-- Buttons -->
                <Grid Margin="0,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="XÁC NHẬN" Grid.Column="0" Margin="0,0,5,0" Height="35" Background="#2B2B2B" Foreground="White" FontWeight="Bold" Command="{Binding ChangePasswordCommand}" CommandParameter="{Binding ElementName=wdChangePass}"/>
                    <Button Content="HỦY BỎ" Grid.Column="1" Margin="5,0,0,0" Height="35" Background="#E1E1E1" Foreground="#333333" FontWeight="Bold" Click="CloseButton_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>