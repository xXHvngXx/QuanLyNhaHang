<Window x:Class="RestaurantManagementSystem.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký tài khoản" Height="500" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="White" CornerRadius="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                        BorderThickness="0" Foreground="Gray" Click="btnClose_Click"/>

                <TextBlock Text="CREATE ACCOUNT" FontSize="26" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2D3436" Margin="0,10,0,0"/>
                <TextBlock Text="Đăng ký thành viên mới cho hệ thống" HorizontalAlignment="Center" 
                           Foreground="Gray" Margin="0,5,0,25"/>

                <TextBlock Text="Tên đăng nhập" Foreground="#636E72" Margin="0,10,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DFE6E9" BorderThickness="1" CornerRadius="10" Padding="5">
                    <TextBox x:Name="txtRegUser" 
                             Text="{Binding RegUser, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" VerticalContentAlignment="Center" Height="30"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#636E72" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DFE6E9" BorderThickness="1" CornerRadius="10" Padding="5">
                    <PasswordBox x:Name="txtRegPass" BorderThickness="0" VerticalContentAlignment="Center" Height="30"/>
                </Border>

                <Button x:Name="btnRegister" Content="ĐĂNG KÝ NGAY" Margin="0,35,0,0" Height="45"
                        Background="#00B894" Foreground="White" FontWeight="Bold"
                        Command="{Binding RegisterCommand}"
                        CommandParameter="{Binding ElementName=txtRegPass}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Đã có tài khoản? Đăng nhập" Margin="0,15,0,0" Background="Transparent" 
                        BorderThickness="0" Foreground="#0984E3" Cursor="Hand" Click="btnBackToLogin_Click"/>
            </StackPanel>

            <Border x:Name="brdSuccess" Background="#27ae60" CornerRadius="20" 
                    Visibility="Collapsed" Opacity="0" VerticalAlignment="Center" 
                    HorizontalAlignment="Center" Padding="30,20" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔" Foreground="White" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="ĐĂNG KÝ THÀNH CÔNG" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Chào mừng thành viên mới!" Foreground="#e0e0e0" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="brdError" Background="#e74c3c" CornerRadius="20" 
                    Visibility="Collapsed" Opacity="0" VerticalAlignment="Center" 
                    HorizontalAlignment="Center" Padding="30,20" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✖" Foreground="White" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtErrorHeader" Text="ĐĂNG KÝ THẤT BẠI" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="txtErrorMessage" Text="Vui lòng kiểm tra lại thông tin!" Foreground="#f5f5f5" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>