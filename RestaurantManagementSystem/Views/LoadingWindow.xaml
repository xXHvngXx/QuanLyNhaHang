<Window x:Class="RestaurantManagementSystem.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading..." 
        Height="350" Width="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="MasterLoadingAnim" RepeatBehavior="Forever">

            <DoubleAnimation Storyboard.TargetProperty="Width"
                             Storyboard.TargetName="ProgressRect"
                             From="0" To="300" Duration="0:0:2">
                <DoubleAnimation.EasingFunction>
                    <PowerEase Power="4" EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Storyboard.TargetName="TxtPercent">
                <DiscreteStringKeyFrame Value="0%" KeyTime="0:0:0" />
                <DiscreteStringKeyFrame Value="12%" KeyTime="0:0:0.6" />
                <DiscreteStringKeyFrame Value="35%" KeyTime="0:0:1.1" />
                <DiscreteStringKeyFrame Value="58%" KeyTime="0:0:1.5" />
                <DiscreteStringKeyFrame Value="89%" KeyTime="0:0:1.8" />
                <DiscreteStringKeyFrame Value="100%" KeyTime="0:0:1.95" />
            </StringAnimationUsingKeyFrames>

            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="MainBorder"
                             From="1" To="0.9" BeginTime="0:0:2" Duration="0:0:0.2" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource MasterLoadingAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border x:Name="MainBorder" Background="White" CornerRadius="25" Width="450" Height="220">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <Grid>
                <StackPanel VerticalAlignment="Center">

                    <TextBlock FontSize="26" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,30">
                        <TextBlock.Foreground>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                                <GradientStop Color="#2d3436" Offset="0"/>
                                <GradientStop Color="#0984e3" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        RESTAURANT <Run Foreground="#0984e3">MASTER</Run>
                    </TextBlock>

                    <StackPanel Width="310">
                        <TextBlock x:Name="TxtPercent" 
                                   Text="0%" 
                                   HorizontalAlignment="Center" 
                                   Foreground="Black" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <Grid Height="16">
                            <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="8"/>

                            <Rectangle x:Name="ProgressRect" 
                                       Width="0" 
                                       HorizontalAlignment="Left" 
                                       Fill="Black" 
                                       RadiusX="5" RadiusY="5" 
                                       Margin="3,2,3,2"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>

                <TextBlock Text="INITIALIZING RESOURCES..." 
                           VerticalAlignment="Bottom" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,15" 
                           Foreground="#b2bec3" 
                           FontSize="9" 
                           FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>