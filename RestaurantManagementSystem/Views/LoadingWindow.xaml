<Window x:Class="RestaurantManagementSystem.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading..." 
        Height="350" Width="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="MasterLoadingAnim">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                             Storyboard.TargetName="ProgressRect"
                             From="0" To="300" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction>
                    <PowerEase Power="3" EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Storyboard.TargetName="TxtPercent">
                <DiscreteStringKeyFrame Value="0%" KeyTime="0:0:0" />
                <DiscreteStringKeyFrame Value="15%" KeyTime="0:0:0.5" />
                <DiscreteStringKeyFrame Value="42%" KeyTime="0:0:1.2" />
                <DiscreteStringKeyFrame Value="78%" KeyTime="0:0:1.8" />
                <DiscreteStringKeyFrame Value="91%" KeyTime="0:0:2.2" />
                <DiscreteStringKeyFrame Value="100%" KeyTime="0:0:2.5" />
            </StringAnimationUsingKeyFrames>

            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="MainBorder"
                             From="1" To="0" BeginTime="0:0:2.7" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource MasterLoadingAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border x:Name="MainBorder" Background="White" CornerRadius="25" Width="450" Height="220">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" Color="#2d3436"/>
            </Border.Effect>

            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="28" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <TextBlock.Foreground>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                                <GradientStop Color="#2d3436" Offset="0"/>
                                <GradientStop Color="#0984e3" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        RESTAURANT <Run Foreground="#0984e3">MASTER</Run>
                    </TextBlock>

                    <StackPanel Width="310">
                        <TextBlock x:Name="TxtPercent" Text="0%" HorizontalAlignment="Center" 
                                   Foreground="#2d3436" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Grid Height="12">
                            <Border Background="#f1f2f6" CornerRadius="6"/>
                            <Rectangle x:Name="ProgressRect" Width="0" HorizontalAlignment="Left" RadiusX="6" RadiusY="6">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#74b9ff" Offset="0"/>
                                        <GradientStop Color="#0984e3" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="INITIALIZING RESOURCES..." 
                           VerticalAlignment="Bottom" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20" 
                           Foreground="#b2bec3" 
                           FontSize="10" 
                           FontWeight="SemiBold"
                           FontStretch="Expanded"/>
            </Grid>
        </Border>
    </Grid>
</Window>